#sort colors
class Solution {
    public void sortColors(int[] nums) {
        for(int i=0;i<nums.length;i++){
          for(int j=i+1;j<nums.length;j++){
             int temp=0;
            if(nums[i]>=nums[j]){
               temp=nums[i];
               nums[i]=nums[j];
               nums[j]=temp;
            }
          }
        }
      
    }

